{
  "$id": "cross_sectional_features.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": [
    "date",
    "symbol",
    "momentum_7d",
    "momentum_30d",
    "momentum_90d",
    "volatility_30d",
    "drawdown_rolling_90d",
    "avg_volume_30d",
    "median_dollar_volume_30d",
    "sector",
    "benchmark",
    "macro_market_bias",
    "macro_regime"
  ],
  "properties": {
    "date": { "type": "string", "format": "date" },
    "symbol": { "type": "string", "minLength": 1 },
    "close": { "type": ["number", "null"] },
    "momentum_7d": { "type": ["number", "null"] },
    "momentum_30d": { "type": ["number", "null"] },
    "momentum_90d": { "type": ["number", "null"] },
    "volatility_30d": { "type": ["number", "null"] },
    "drawdown_rolling_90d": { "type": ["number", "null"] },
    "avg_volume_30d": { "type": ["number", "null"] },
    "median_dollar_volume_30d": { "type": ["number", "null"] },
    "amihud_30d": { "type": ["number", "null"] },
    "spread_proxy_30d": { "type": ["number", "null"] },
    "roe": { "type": ["number", "null"] },
    "roa": { "type": ["number", "null"] },
    "debt_to_equity": { "type": ["number", "null"] },
    "current_ratio": { "type": ["number", "null"] },
    "analyst_count": { "type": ["integer", "null"] },
    "recommendation_mean": { "type": ["number", "null"] },
    "beta": { "type": ["number", "null"] },
    "sector": { "type": "string" },
    "benchmark": { "type": "string" },
    "sector_dummy": { "type": "string" },
    "macro_market_bias": { "type": ["number", "null"] },
    "macro_regime": { "type": "string", "enum": ["RISK_ON", "NEUTRAL", "RISK_OFF"] },
    "macro_fed_funds": { "type": ["number", "null"] },
    "macro_cpi_yoy": { "type": ["number", "null"] },
    "macro_vix": { "type": ["number", "null"] },
    "macro_dxy": { "type": ["number", "null"] },
    "macro_qe_qt_proxy": { "type": ["number", "null"] },
    "macro_tga_proxy": { "type": ["number", "null"] },
    "macro_real_rate_10y": { "type": ["number", "null"] },
    "macro_yield_spread_10y_2y": { "type": ["number", "null"] },
    "macro_forward_guidance_proxy": { "type": ["number", "null"] }
  },
  "additionalProperties": true
}
