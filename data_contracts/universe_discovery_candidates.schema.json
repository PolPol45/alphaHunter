{
  "$id": "universe_discovery_candidates.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": ["generated_at", "provider", "candidates"],
  "properties": {
    "generated_at": { "type": "string", "format": "date-time" },
    "provider": { "type": "string" },
    "summary": { "type": "object" },
    "candidates": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["symbol", "candidate_origin"],
        "properties": {
          "symbol": { "type": "string", "minLength": 1 },
          "candidate_origin": { "type": "string" }
        },
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": true
}
